	Keywords = {Address-Event-Representation, Artificial Intelligence (incl. Robotics), Computer-Aided Engineering (CAD, CAE) and Design, Computer Imaging, Vision, Pattern Recognition and Graphics, FPGA, Image Processing and Computer Vision, Pattern Recognition, silicon retina, Simulation and Modeling, stereo vision},
	Month = jan,
	Number = {6927},
