@article{Barlow_etal67,
	Abstract = {1. Binocularly driven units were investigated in the cat's
		  primary visual cortex. 2. It was found that a stimulus
		  located correctly in the visual fields of both eyes was
		  more effective in driving the units than a monocular
		  stimulus, and much more effective than a binocular stimulus
		  which was correctly positioned in only one eye: the
		  response to the correctly located image in one eye is
		  vetoed if the image is incorrectly located in the other
		  eye. 3. The vertical and horizontal disparities of the
		  paired retinal images that yielded the maximum response
		  were measured in 87 units from seven cats: the range of
		  horizontal disparities was 6Â·6$\,^{\circ}$, of vertical disparities
		  2Â·2$\,^{\circ}$. 4. With fixed convergence, different units will be
		  optimally excited by objects lying at different distances.
		  This may be the basic mechanism underlying depth
		  discrimination in the cat.},
	Author = {Barlow, H. B. and Blakemore, C. and Pettigrew, J. D.},
	Copyright = {{\copyright} 1967 The Physiological Society},
	Doi = {10.1113/jphysiol.1967.sp008360},
	Issn = {1469-7793},
	Journal = {The Journal of Physiology},
	Month = nov,
	Number = {2},
	Pages = {327--342},
	Title = {The neural mechanism of binocular depth discrimination},
	Url = {http://onlinelibrary.wiley.com/doi/10.1113/jphysiol.1967.sp008360/abstract},
	Volume = {193},
	Year = {1967},
