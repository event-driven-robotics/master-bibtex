	Citeulike-Linkout-2 = {http://view.ncbi.nlm.nih.gov/pubmed/16597727},
	Citeulike-Linkout-3 = {http://www.hubmed.org/display.cgi?uids=16597727},
	Day = {5},
	Doi = {10.1523/JNEUROSCI.5159-05.2006},
	Issn = {1529-2401},
	Journal = {The Journal of neuroscience : the official journal of the Society for Neuroscience},
	Keywords = {decisionmaking, hebblearning, matchinglaw},
	Month = apr,
