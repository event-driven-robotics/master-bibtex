@article{Laughlin_Sejnowski03,
	Abstract = {Brains perform with remarkable efficiency, are capable of
		  prodigious computation, and are marvels of communication.
		  We are beginning to understand some of the geometric,
		  biophysical, and energy constraints that have governed the
		  evolution of cortical networks. To operate efficiently
		  within these constraints, nature has optimized the
		  structure and function of cortical networks with design
		  principles similar to those used in electronic networks.
