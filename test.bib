@inproceedings{Serrano-Gotarredona_etal13a,
	Abstract = {This paper presents a new DVS sensor with one order of
		  magnitude improved contrast sensitivity over previous
		  reported DVSs. This sensor has been applied to a
		  bio-inspired event-based binocular system that performs 3D
		  event-driven reconstruction of a scene. Events from two DVS
		  sensors are matched by using precise timing information of
		  their ocurrence. To improve matching reliability,
