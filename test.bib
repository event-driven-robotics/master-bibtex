@inproceedings{Khan_etal08,
	Abstract = {SpiNNaker is a novel chip - based on the ARM processor -
		  which is designed to support large scale spiking neural
		  networks simulations. In this paper we describe some of the
		  features that permit SpiNNaker chips to be connected
		  together to form scalable massively-parallel systems. Our
		  eventual goal is to be able to simulate neural networks
		  consisting of 109 neurons running in dasiareal timepsila,
		  by which we mean that a similarly sized collection of
		  biological neurons would run at the same speed. In this
		  paper we describe the methods by which neural networks are
		  mapped onto the system, and how features designed into the
		  chip are to be exploited in practice. We will also describe
		  the modelling and verification activities by which we hope
		  to ensure that, when the chip is delivered, it will work as
		  anticipated.},
	Author = {Khan, M.M. and Lester, D.R. and Plana, L.A. and Rast, A. and Jin, X. and Painkras, E. and Furber, S.B.},
	Booktitle = {{IEEE} {International} {Joint} {Conference} on {Neural} {Networks}, 2008. {IJCNN} 2008. ({IEEE} {World} {Congress} on {Computational} {Intelligence})},
	Doi = {10.1109/IJCNN.2008.4634199},
	Keywords = {ARM processor, Biological neural networks, biological neurons, Communication system control, computational modeling, Computer architecture, Concurrent computing, large scale spiking neural networks simulations, Large-scale systems, massively-parallel chip multiprocessor, microprocessor chips, multiprocessor interconnection networks, Network-on-a-chip, neural nets, Neural networks, Neurons, Routing, SpiNNaker chips},
	Month = jun,
	Pages = {2849--2856},
	Shorttitle = {{SpiNNaker}},
	Title = {{SpiNNaker}: {Mapping} neural networks onto a massively-parallel chip multiprocessor},
	Year = {2008},
